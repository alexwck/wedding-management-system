# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# NEVER commit real secrets - this file uses <PLACEHOLDER> syntax for all
# sensitive values. Replace placeholders with actual values in .env.local only.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Required: All environments)
# -----------------------------------------------------------------------------
# Local: Run `npx supabase start` to get local values
# Production: Get from Supabase Dashboard → Settings → API
#
# Environments: local, production
NEXT_PUBLIC_SUPABASE_URL=<YOUR_SUPABASE_PROJECT_URL>
# Example production: https://abcdefghij.supabase.co
# Example local:      http://localhost:54321

# Environments: local, production
NEXT_PUBLIC_SUPABASE_ANON_KEY=<YOUR_ANON_KEY>
# Get from Supabase Dashboard → Settings → API → Project API keys

# Environments: production only (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SERVICE_ROLE_KEY>
# WARNING: This key bypasses RLS - keep secret, never commit to git
# Get from Supabase Dashboard → Settings → API → Project API keys

# Environments: production only
DATABASE_URL=<YOUR_DATABASE_URL>
# Free plan: Use direct connection (port 5432)
# Format: postgresql://postgres.<PROJECT_REF>:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Pro plan: Use pooled connection (port 6543) for pgbouncer
# Format: postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Vercel (Required: Production)
# -----------------------------------------------------------------------------
# Get from Vercel Dashboard → Project Settings → Git → Repository
# Only needed for programmatic deployments
VERCEL_TOKEN=<YOUR_VERCEL_TOKEN>
# Generate at vercel.com/account/tokens

# -----------------------------------------------------------------------------
# Sentry (Required: Production only)
# -----------------------------------------------------------------------------
# Get from Sentry Dashboard → Project Settings → Keys
# Environments: production only
SENTRY_DSN=<YOUR_SENTRY_DSN>
# Example: https://abc123def456@o123456.ingest.sentry.io/1234567

# Sentry Org (optional - for source map uploads)
# Environments: production only
SENTRY_ORG=<YOUR_SENTRY_ORG_SLUG>

# Sentry Project (optional - for source map uploads)
# Environments: production only
SENTRY_PROJECT=<YOUR_SENTRY_PROJECT_SLUG>

# Sentry Auth Token (optional - for source map uploads via CLI)
# Environments: production only
SENTRY_AUTH_TOKEN=<YOUR_SENTRY_AUTH_TOKEN>
# Generate at sentry.io/settings/account/settings/auth-tokens/

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable/disable features for testing
# Environments: local, production

# Disable Sentry in local development (recommended)
# NEXT_PUBLIC_SENTRY_ENABLED=false

# Enable verbose logging for debugging
# NEXT_PUBLIC_DEBUG=true

# -----------------------------------------------------------------------------
# Environment-Specific Notes
# -----------------------------------------------------------------------------
#
# LOCAL DEVELOPMENT:
# - Use local Supabase project (npx supabase start)
# - No Sentry required (errors logged to console)
# - No DATABASE_URL needed (uses NEXT_PUBLIC_SUPABASE_URL)
#
# PRODUCTION (Vercel):
# - Add all variables to Vercel Dashboard → Project Settings → Environment Variables
# - Mark SUPABASE_SERVICE_ROLE_KEY, DATABASE_URL, SENTRY_DSN as "production only"
# - Mark NEXT_PUBLIC_* variables as "all environments"
# - NEVER commit real values to git
#
# FREE PLAN LIMITS (Monitor weekly at provider dashboards):
# - Supabase: 500MB DB, 2GB bandwidth, 50K MAU, 60 connections
# - Vercel: 100GB bandwidth, personal use only
# - Sentry: 10K errors/month, 7-day retention
#
# ALERT THRESHOLDS (80% of limits):
# - Supabase DB > 400MB → Archive data or upgrade
# - Supabase bandwidth > 1.6GB → Optimize or upgrade
# - Supabase connections > 48 → Optimize queries or upgrade
# - Vercel bandwidth > 80GB → Optimize assets or upgrade
# - Sentry errors > 8K → Reduce noise or upgrade
