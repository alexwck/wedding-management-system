# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
playwright-report/
test-results/
# Playwright storageState files (one per role, written by tests/e2e/auth.setup.ts)
playwright/.auth/
.playwright-mcp/

# claude code
.claude/settings.local.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.tmp
*.swp

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.idea/
.vscode/

# Supabase
.supabase/
.supabase/.temp/

# speckit-generated noise (auto-deleted after implement)
specs/*/quickstart.md
specs/*/checklists/requirements.md
.specify/feature.json
.specify/init-options.json
.specify/integration.json
.specify/workflows/workflow-registry.json

# Playwright snapshots (generated during --update-snapshots, not committed)
*.test.ts-snapshots/
